import 'SimplePRG.primitive';
import 'BaseAssumption.game';
import 'DerivedSecurity.game';

proof:

let:
    Int lambda;
    SimplePRG G = SimplePRG(lambda);

theorem:
    DerivedSecurity(G);

games:
    DerivedSecurity(G).Real against DerivedSecurity(G).Adversary;
    DerivedSecurity(G).Random against DerivedSecurity(G).Adversary;
